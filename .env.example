# ─────────────────────────────────────────────────────────────
# LL Studio Inspector (Web) — Konfiguration
# ALLES optional. Ohne Keys läuft die Recherche lokal über den Browser (Playwright)
# und alle Bewertungen regelbasiert. Keys verbessern Qualität & Geschwindigkeit.
# Diese Werte können auch in der App unter „Settings“ gesetzt werden.
# ─────────────────────────────────────────────────────────────

# --- KI (optional: bessere Analyse, Texte, Report) ---
AI_API_KEY=
AI_PROVIDER=           # anthropic | openai | ollama
AI_MODEL=              # z. B. claude-opus-4-8 / gpt-4o-mini / llama3.1
AI_BASE_URL=           # nur für openai-kompatible Provider

# --- KI-Vorschau-Provider (optional: „KI-Vorschau generieren“ in der Stil-Vorschau) ---
# SICHERHEIT: API-Keys NUR hier oder in .env.local eintragen (beide sind in .gitignore, NIEMALS committen).
# Keys werden ausschließlich SERVERSEITIG genutzt und NIEMALS im Frontend/Log angezeigt.
# API-Keys werden NICHT automatisch aus ChatGPT/Browsern/Accounts gezogen – du trägst sie bewusst selbst ein.
# ALLE optional. Ohne Key funktioniert IMMER der manuelle Prompt-Export (kopieren / .txt).
V0_API_KEY=
V0_MODEL=
CLAUDE_API_KEY=
CLAUDE_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
DEFAULT_AI_PREVIEW_PROVIDER=manual   # v0 | claude | openai | ollama | manual

# --- Suche (optional: bessere/schnellere Treffer) ---
# leer = lokale Browser-Suche (Startpage/Bing/DuckDuckGo). Kein Key nötig.
SEARCH_PROVIDER=       # auto | brave | serpapi | tavily | local
BRAVE_API_KEY=
SERPAPI_KEY=
TAVILY_API_KEY=

# --- Speicherort (Deployment) ---
# Alle Daten (SQLite-DB, Projekte, Reports, Prompts, Previews, Settings) liegen hier.
# Lokal leer lassen → ./.data ; auf Railway/Render auf den Volume-Mount zeigen (z. B. /data).
LLI_DATA_DIR=

# --- Allgemein ---
MAX_RESULTS=20
DEFAULT_COUNTRY=Germany
HEADLESS=true

# ─────────────────────────────────────────────────────────────
# SICHERHEIT / ANMELDUNG (internes Tool) — NUR Platzhalter, echte Werte in .env.local / Secret Manager
# Solange GOOGLE_CLIENT_ID leer ist, läuft die App LOKAL offen (mit Warnbanner);
# in PRODUKTION wird der unkonfigurierte Zustand hart verweigert (503).
# ─────────────────────────────────────────────────────────────
# Auth.js / NextAuth v5
AUTH_SECRET=                 # langer zufälliger Wert: `npx auth secret` oder `openssl rand -base64 33`
AUTH_URL=                    # Basis-URL, z. B. http://localhost:3000 (Dev) / https://interntool.ll-studio.de (Prod)
AUTH_TRUST_HOST=             # auf Railway/Render/hinter Proxy: true  (lokal leer lassen)
# Google OAuth (Google Cloud Console → APIs & Services → Anmeldedaten → OAuth-Client, Typ „Webanwendung“)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Geschlossene Zugriffssteuerung (serverseitig geprüft) — Komma-separierte, exakte E-Mail-Adressen
ALLOWED_GOOGLE_EMAILS=luk72211@gmail.com
# Optional: erlaubte Google-Workspace-Domain (leer lassen, wenn kein Workspace) — Domain ALLEIN reicht nie
ALLOWED_GOOGLE_DOMAIN=
# Erst-Admins (Teilmenge der Allowlist); erhalten Rolle „admin“ beim ersten Login
INITIAL_ADMIN_EMAILS=luk72211@gmail.com
# Zweite interne Sicherheitsfreigabe (Passwortsperre nach Google-Login)
# Hash wird per `npm run setup:dev-access-password` gesetzt — NIE Klartext hier.
SECURITY_ADMIN_EMAIL=        # verifizierte Sicherheits-E-Mail (für spätere Passwortänderungs-Bestätigung)
